{
  "name": "support-ticket-llm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run typecheck",
    "eval:retrieval": "npm run eval:retrieval --workspace @support-ticket-llm/core",
    "eval:answers": "tsx scripts/evaluate-answers.ts",
    "check:milestone5": "node scripts/check-milestone5.mjs",
    "check:milestone6": "node scripts/check-milestone6.mjs",
    "seed": "npm run seed --workspace @support-ticket-llm/core",
    "dev:api": "npm run dev --workspace @support-ticket-llm/api",
    "dev:mcp": "npm run dev --workspace @support-ticket-llm/mcp-server",
    "dev:ui": "npm run dev --workspace @support-ticket-llm/ui"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
