{
  "name": "support-ticket-llm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run typecheck",
    "dev:api": "npm run dev --workspace @support-ticket-llm/api",
    "dev:mcp": "npm run dev --workspace @support-ticket-llm/mcp-server",
    "dev:ui": "npm run dev --workspace @support-ticket-llm/ui"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
