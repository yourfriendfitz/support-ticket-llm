# Local defaults. The deterministic mock adapter is the default and needs no secrets.
INFERENCE_PROVIDER=deterministic_mock

# Optional future Lambda HTTP inference adapter.
# Set INFERENCE_PROVIDER=aws_lambda_http only after the Terraform scaffold is deployed.
INFERENCE_LAMBDA_URL=
INFERENCE_LAMBDA_API_KEY=
INFERENCE_MAX_CANDIDATES=5
INFERENCE_MAX_SNIPPET_CHARACTERS=480
INFERENCE_MAX_GENERATED_TOKENS=256
INFERENCE_REQUEST_TIMEOUT_MS=15000

# Local service defaults.
MCP_SERVER_URL=http://mcp-server:4001/mcp
API_HOST=0.0.0.0
API_PORT=4000
