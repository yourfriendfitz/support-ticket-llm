{
  "name": "@support-ticket-llm/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build --workspace @support-ticket-llm/adapters && tsc -p tsconfig.build.json",
    "dev": "npm run build --workspace @support-ticket-llm/adapters && tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "npm run build --workspace @support-ticket-llm/adapters && vitest run",
    "typecheck": "npm run build --workspace @support-ticket-llm/adapters && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@support-ticket-llm/adapters": "0.1.0",
    "@support-ticket-llm/core": "0.1.0",
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/client": "2.0.0-alpha.2",
    "fastify": "^5.8.5"
  }
}
